# Secret Key for Flask Session and CSRF Protection
SECRET_KEY=change-me-to-a-random-secret-key

# Database Configuration (Using SQLite for ease of run or MySQL if configured)
USE_SQLITE=true
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_NAME=pdf_compressor

# Admin Password (REQUIRED: set a strong password)
ADMIN_PASSWORD=

# Application Environment
FLASK_ENV=development
FLASK_APP=app.py
